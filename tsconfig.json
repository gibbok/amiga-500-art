{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "tool/dist",
    "rootDir": "tool/src"
  },
  "include": [
    "tool/src/**/*.ts"
  ]
}
